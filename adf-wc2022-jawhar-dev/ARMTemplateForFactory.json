				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_http_statsbomb_binary')]",
				"[concat(variables('factoryId'), '/datasets/ds_adls_landing_binary')]"
			]
		},
